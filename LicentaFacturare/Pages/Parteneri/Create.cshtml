@page
@model LicentaFacturare.Pages.Parteneri.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Adauga partener nou</h1>

<h4>Partener</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Partener.Cod" class="control-label"></label>
                <input asp-for="Partener.Cod" class="form-control" aria-required="true"/>
                <span asp-validation-for="Partener.Cod" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Partener.Denumire" class="control-label"></label>
                <input asp-for="Partener.Denumire" class="form-control" aria-required="true"/>
                <span asp-validation-for="Partener.Denumire" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Partener.CnpCodFiscal" class="control-label"></label>
                <input asp-for="Partener.CnpCodFiscal" class="form-control" aria-required="true"/>
                <span asp-validation-for="Partener.CnpCodFiscal" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Partener.NrRegComertului" class="control-label"></label>
                <input asp-for="Partener.NrRegComertului" class="form-control" />
                <span asp-validation-for="Partener.NrRegComertului" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Partener.Tara" class="control-label"></label>
                <input asp-for="Partener.Tara" class="form-control" />
                <span asp-validation-for="Partener.Tara" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Partener.Judet" class="control-label"></label>
                <input asp-for="Partener.Judet" class="form-control" />
                <span asp-validation-for="Partener.Judet" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Partener.Localitate" class="control-label"></label>
                <input asp-for="Partener.Localitate" class="form-control" />
                <span asp-validation-for="Partener.Localitate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Partener.Adresa" class="control-label"></label>
                <input asp-for="Partener.Adresa" class="form-control" />
                <span asp-validation-for="Partener.Adresa" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Partener.ContBancar" class="control-label"></label>
                <input asp-for="Partener.ContBancar" class="form-control" />
                <span asp-validation-for="Partener.ContBancar" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Partener.TipPartener" class="control-label"></label>
                <select asp-for="Partener.TipPartener" class="form-control" aria-required="true"
                        asp-items="Html.GetEnumSelectList<LicentaFacturare.Models.TipPartener>()">
                    <option value="">-- Selecteaza --</option>
                </select>
                <span asp-validation-for="Partener.TipPartener" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Adauga" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Inapoi la lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
