@page
@model LicentaFacturare.Pages.Facturi.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Creaza factura noua</h1>

<h4>Factura</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Factura.PartenerId" class="control-label"></label>
                <select asp-for="Factura.PartenerId" class="form-control" asp-items="ViewBag.PartenerId"></select>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Factura.Serie" class="control-label"></label>
                <input asp-for="Factura.Serie" class="form-control" aria-required="true"/>
                <span asp-validation-for="Factura.Serie" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Factura.Numar" class="control-label"></label>
                <input asp-for="Factura.Numar" class="form-control" aria-required="true"/>
                <span asp-validation-for="Factura.Numar" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Factura.DataEmitere" class="control-label"></label>
                <input asp-for="Factura.DataEmitere" class="form-control" aria-required="true"/>
                <span asp-validation-for="Factura.DataEmitere" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Factura.DataScadenta" class="control-label"></label>
                <input asp-for="Factura.DataScadenta" class="form-control" aria-required="true"/>
                <span asp-validation-for="Factura.DataScadenta" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Factura.TipFactura" class="control-label"></label>
                <select asp-for="Factura.TipFactura"
                         class="form-control"
                         asp-items="Html.GetEnumSelectList<LicentaFacturare.Models.TipFactura>()">
                    <option value="">-- Selecteaza --</option>
                </select>
                <span asp-validation-for="Factura.TipFactura" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Factura.Stare" class="control-label"></label>
                <select asp-for="Factura.Stare"
                        class="form-control"
                        asp-items="Html.GetEnumSelectList<LicentaFacturare.Models.StareFactura>()">
                </select>
                <span asp-validation-for="Factura.Stare" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Adauga" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Inapoi la lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
